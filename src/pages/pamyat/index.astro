---
import Base from '../../layouts/Base.astro';
import { characters, things } from '../../lib/memory';
const base = import.meta.env.BASE_URL;
---
<Base title="Память мышонка">
  <section class="hero" style="padding-bottom:0.5rem">
    <div class="kicker">что мышонок уже знает</div>
    <h1>Память</h1>
    <p>Все существа, с кем мышонок познакомился, и всё, что он узнал о большом мире.</p>
  </section>

  <h2 class="section-title">Существа <span class="count">{characters.length}</span></h2>
  <div class="grid-2">
    {characters.map((c) => (
      <a class="card" href={`${base}/creatures/${c.id}`}>
        <span class="tag friend">{c.status}</span>
        <h3><span class="emoji" aria-hidden="true">{c.emoji}</span> {c.name}</h3>
        <div class="meta">{c.appearance}</div>
        <ul class="fact-list">
          {c.facts.slice(0, 2).map((f) => <li>{f}</li>)}
        </ul>
      </a>
    ))}
  </div>

  <h2 class="section-title">Что я узнал <span class="count">{things.length}</span></h2>
  <div class="grid-2">
    {things.map((t) => (
      <a class="card" href={`${base}/things/${t.id}`}>
        <span class="tag thing">вещь</span>
        <h3><span class="emoji" aria-hidden="true">{t.emoji}</span> {t.name}</h3>
        <div class="meta">{t.whatIsIt}</div>
        <ul class="fact-list">
          {t.facts.slice(0, 2).map((f) => <li>{f}</li>)}
        </ul>
      </a>
    ))}
  </div>
</Base>
