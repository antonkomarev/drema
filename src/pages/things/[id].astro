---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { things, getCharacter } from '../../lib/memory';
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  return things.map((t) => ({ params: { id: t.id }, props: { thing: t } }));
}

const { thing } = Astro.props;
const allStories = await getCollection('stories');
const firstStory = allStories.find((s) => s.data.number === thing.firstInStory);
const teacher = thing.learnedFrom ? getCharacter(thing.learnedFrom) : undefined;
---
<Base title={thing.name}>
  <div class="story-head">
    <span class="tag thing">вещь</span>
    <h1><span aria-hidden="true">{thing.emoji}</span> {thing.name}</h1>
    <div class="meta">{thing.whatIsIt}</div>
  </div>

  <article class="story" style="font-size:1.08rem; line-height:1.7">
    <h2 style="font-family:var(--font-display); font-weight:400; font-size:1.3rem; margin:0.4rem 0 0.5rem">Что мышонок узнал</h2>
    <ul class="fact-list">
      {thing.facts.map((f) => <li>{f}</li>)}
    </ul>

    {teacher && (
      <p style="margin-top:1.4rem">
        Об этом рассказал{' '}
        <a href={`${base}/creatures/${teacher.id}`}>{teacher.emoji} {teacher.name}</a>.
      </p>
    )}

    {thing.leadsToCharacter && (
      <p style="color:var(--muted)">
        Мышонок услышал про <strong>{thing.leadsToCharacter}</strong>, но пока с ним не знаком.
      </p>
    )}

    {firstStory && (
      <p style="color:var(--muted)">
        Впервые — в сказке{' '}
        <a href={`${base}/tales/${firstStory.id}`}>«{firstStory.data.title}»</a>.
      </p>
    )}
  </article>

  <nav class="pager"><a href={`${base}/things`}>← Все вещи</a><span></span></nav>
</Base>
