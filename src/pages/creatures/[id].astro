---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { characters } from '../../lib/memory';
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  return characters.map((c) => ({ params: { id: c.id }, props: { character: c } }));
}

const { character } = Astro.props;
const allStories = await getCollection('stories');
const metStory = allStories.find((s) => s.data.number === character.metInStory);
---
<Base title={character.name}>
  <div class="story-head">
    <span class="tag friend">{character.status}</span>
    <h1><span aria-hidden="true">{character.emoji}</span> {character.name}</h1>
    <div class="meta">{character.appearance}</div>
  </div>

  <article class="story" style="font-size:1.08rem; line-height:1.7">
    {character.home && <p><strong>Где живёт:</strong> {character.home}</p>}

    <h2 style="font-family:var(--font-display); font-weight:400; font-size:1.3rem; margin:1.2rem 0 0.5rem">Что мышонок узнал</h2>
    <ul class="fact-list">
      {character.facts.map((f) => <li>{f}</li>)}
    </ul>

    {metStory && (
      <p style="margin-top:1.4rem; color:var(--muted)">
        Познакомились в сказке{' '}
        <a href={`${base}/tales/${metStory.id}`}>«{metStory.data.title}»</a>.
      </p>
    )}
  </article>

  <nav class="pager"><a href={`${base}/memories`}>← Вся память</a><span></span></nav>
</Base>
