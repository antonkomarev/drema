---
import Base from '../../layouts/Base.astro';
import { characters } from '../../lib/memory';
const base = import.meta.env.BASE_URL;
---
<Base title="Существа">
  <section class="hero" style="padding-bottom:0.5rem">
    <div class="kicker">с кем мышонок познакомился</div>
    <h1>Существа</h1>
    <p>Все, кого мышонок встретил на прогулках, — друзья и соседи его маленького мира.</p>
  </section>

  <h2 class="section-title">Существа <span class="count">{characters.length}</span></h2>
  <div class="grid-2">
    {characters.map((c) => (
      <a class="card" href={`${base}/creatures/${c.id}`}>
        <span class="tag friend">{c.status}</span>
        <h3><span class="emoji" aria-hidden="true">{c.emoji}</span> {c.name}</h3>
        <div class="meta">{c.appearance}</div>
        <ul class="fact-list">
          {c.facts.slice(0, 2).map((f) => <li>{f}</li>)}
        </ul>
      </a>
    ))}
  </div>
</Base>
