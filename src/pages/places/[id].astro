---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { places } from '../../lib/memory';
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  return places.map((p) => ({ params: { id: p.id }, props: { place: p } }));
}

const { place } = Astro.props;
const allStories = (await getCollection('stories')).sort((a, b) => a.data.number - b.data.number);
const here = allStories.filter((s) => s.data.place === place.id);
---
<Base title={place.name}>
  <div class="story-head">
    <span class="tag place">место</span>
    <h1><span aria-hidden="true">{place.emoji}</span> {place.name}</h1>
    <div class="meta">{place.whatIsIt}</div>
  </div>

  <article class="story" style="font-size:1.08rem; line-height:1.7">
    <h2 style="font-family:var(--font-display); font-weight:400; font-size:1.3rem; margin:0.4rem 0 0.5rem">Что мышонок знает об этом месте</h2>
    <ul class="fact-list">
      {place.facts.map((f) => <li>{f}</li>)}
    </ul>

    {here.length > 0 && (
      <>
        <h2 style="font-family:var(--font-display); font-weight:400; font-size:1.3rem; margin:1.4rem 0 0.5rem">Что здесь случилось</h2>
        <ul class="fact-list">
          {here.map((s) => (
            <li><a href={`${base}/tales/${s.id}`}>«{s.data.title}»</a></li>
          ))}
        </ul>
      </>
    )}
  </article>

  <nav class="pager"><a href={`${base}/places`}>← Все места</a><span></span></nav>
</Base>
