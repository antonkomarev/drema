---
import '../styles/global.css';
import ReadingControls from '../components/ReadingControls.astro';

const { title = 'Мышонок Мышь', description = 'Сказки о мышонке Мыше и его маленьком мире.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Шрифты -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Kurale&family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;1,7..72,400&display=swap&subset=cyrillic"
      rel="stylesheet"
    />

    <!-- Тема выставляется ДО отрисовки, чтобы не было «моргания» -->
    <script is:inline define:vars={{ base }}>
      window.__BASE__ = base;
      (function () {
        try {
          var saved = localStorage.getItem('mt-theme');
          var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.dataset.theme = saved || sys;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site">
      <div class="site-inner">
        <a class="brand" href={base}><span aria-hidden="true">🐭</span> Мыш-мышь</a>
        <nav class="nav">
          <button
            class="nav-toggle"
            id="nav-toggle"
            type="button"
            aria-label="Меню"
            aria-controls="nav-menu"
            aria-expanded="false"
          >
            <span class="nav-toggle-bar" aria-hidden="true"></span>
            <span class="nav-toggle-bar" aria-hidden="true"></span>
            <span class="nav-toggle-bar" aria-hidden="true"></span>
          </button>
          <div class="nav-menu" id="nav-menu" data-open="false">
            <a href={base}>Сказки</a>
            <a href={`${base}/creatures`}>Существа</a>
            <a href={`${base}/things`}>Вещи</a>
            <a href={`${base}/places`}>Места</a>
            <ReadingControls />
          </div>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site">
      <div class="wrap">
        <p class="owl">Совы летают на рассвете и в сумерках — а мышонок в это время уже дома.</p>
        <p>Сказки о мышонке Мыше · сделано с теплом</p>
        <p><button id="clear-history" class="link-btn">Очистить историю чтения</button></p>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var b = document.getElementById('clear-history');
        if (b) b.addEventListener('click', function () {
          try { localStorage.removeItem('mt-history'); } catch (e) {}
          location.reload();
        });

        // Мобильное меню-гамбургер
        var toggle = document.getElementById('nav-toggle');
        var menu = document.getElementById('nav-menu');
        if (toggle && menu) {
          function setMenu(open) {
            menu.dataset.open = String(open);
            toggle.setAttribute('aria-expanded', String(open));
          }
          toggle.addEventListener('click', function () {
            setMenu(menu.dataset.open !== 'true');
          });
          // Клик по ссылке закрывает меню
          menu.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', function () { setMenu(false); });
          });
          // Клик вне меню закрывает его
          document.addEventListener('click', function (e) {
            if (!menu.contains(e.target) && !toggle.contains(e.target)) setMenu(false);
          });
          // Esc закрывает меню
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') setMenu(false);
          });
        }
      })();
    </script>
  </body>
</html>
